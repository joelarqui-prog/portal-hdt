<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Portal – Hospital Docente de Trujillo</title>
  <style>
    :root{
      --bg:#f6f8fb;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#475569;
      --primary:#0066cc;
      --ok:#16a34a;
      --warn:#f59e0b;
      --bad:#dc2626;
      --line:#e2e8f0;
      --shadow: 0 10px 25px rgba(2,6,23,.08);
      --radius:14px;
      --max:1200px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Noto Sans", "Apple Color Emoji","Segoe UI Emoji";
      color:var(--text);
      background:linear-gradient(180deg,#ffffff 0%, var(--bg) 35%, var(--bg) 100%);
    }
    a{color:var(--primary); text-decoration:none}
    a:hover{text-decoration:underline}
    .wrap{max-width:var(--max); margin:0 auto; padding:22px}
    header{
      background:rgba(255,255,255,.75);
      backdrop-filter: blur(10px);
      border:1px solid var(--line);
      border-radius:18px;
      box-shadow: var(--shadow);
      padding:18px 18px 14px;
    }
    .top{
      display:flex;
      gap:14px;
      align-items:center;
      justify-content:space-between;
      flex-wrap:wrap;
    }
    .brand{
      display:flex;
      gap:12px;
      align-items:center;
      min-width:260px;
    }
    .logo{
      width:44px;height:44px;border-radius:12px;
      background:linear-gradient(135deg,var(--primary),#1d4ed8);
      display:grid;place-items:center;
      color:#fff;font-weight:800;
      letter-spacing:.5px;
    }
    .title h1{margin:0; font-size:18px; line-height:1.2}
    .title p{margin:4px 0 0; color:var(--muted); font-size:13px}
    nav{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }
    .chip{
      display:inline-flex; gap:8px; align-items:center;
      border:1px solid var(--line);
      background:#fff;
      padding:8px 10px;
      border-radius:999px;
      font-size:13px;
      color:var(--text);
    }
    .chip b{font-weight:700}
    .btn{
      display:inline-flex; align-items:center; gap:8px;
      padding:10px 12px;
      border-radius:12px;
      background:var(--primary);
      color:#fff;
      border:1px solid rgba(0,0,0,.05);
      font-weight:700;
      font-size:13px;
      box-shadow: 0 10px 18px rgba(0,102,204,.18);
    }
    .btn.secondary{
      background:#fff;
      color:var(--text);
      box-shadow:none;
      border:1px solid var(--line);
    }
    .grid{
      display:grid;
      gap:16px;
      margin-top:18px;
    }
    .kpis{grid-template-columns: repeat(4, minmax(0,1fr));}
    .main{grid-template-columns: 1.5fr 1fr;}
    .card{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow: var(--shadow);
      padding:14px;
    }
    .kpi .label{color:var(--muted); font-size:12px}
    .kpi .value{font-size:22px; font-weight:800; margin-top:6px}
    .badge{
      display:inline-flex; align-items:center; gap:8px;
      margin-top:10px;
      font-size:12px;
      padding:6px 10px;
      border-radius:999px;
      border:1px solid var(--line);
      color:var(--muted);
      width:fit-content;
      background:#fff;
    }
    .dot{width:10px;height:10px;border-radius:999px; background:var(--ok)}
    .dot.warn{background:var(--warn)}
    .dot.bad{background:var(--bad)}

    h2{font-size:14px; margin:0 0 10px}
    .muted{color:var(--muted); font-size:13px}
    table{
      width:100%;
      border-collapse:collapse;
      font-size:13px;
      overflow:hidden;
      border-radius:12px;
      border:1px solid var(--line);
      background:#fff;
    }
    th,td{padding:10px 10px; border-bottom:1px solid var(--line); text-align:left; vertical-align:top}
    th{background:#f8fafc; color:#0f172a; font-size:12px}
    tr:last-child td{border-bottom:0}
    .status{
      display:inline-flex; align-items:center; gap:8px;
      padding:4px 8px; border-radius:999px;
      border:1px solid var(--line);
      background:#fff;
      font-size:12px;
      color:var(--muted);
    }
    .status .dot{width:8px;height:8px}
    .cols{display:grid; gap:12px}
    .links{display:flex; gap:10px; flex-wrap:wrap}
    .footer{
      margin:18px 0 6px;
      color:var(--muted);
      font-size:12px;
      text-align:center;
    }
    @media (max-width: 980px){
      .kpis{grid-template-columns: repeat(2, minmax(0,1fr));}
      .main{grid-template-columns: 1fr;}
      nav{justify-content:flex-start}
    }
  </style>
</head>

<body>
  <div class="wrap">
    <header>
      <div class="top">
        <div class="brand">
          <div class="logo">HDT</div>
          <div class="title">
            <h1>Hospital Docente de Trujillo — Portal de Seguimiento</h1>
            <p>Gestión BIM/VDC · Métricas · Documentación (ACC) · Incidencias · Reportes</p>
          </div>
        </div>

        <nav>
          <span class="chip">Fase: <b>RIBA 3–4</b></span>
          <span class="chip">Corte: <b id="cutoff">—</b></span>
          <a class="btn secondary" id="btnAcc" href="#" target="_blank" rel="noreferrer">ACC</a>
          <a class="btn secondary" id="btnRev" href="#" target="_blank" rel="noreferrer">Revizto</a>
          <a class="btn" id="btnPbi" href="#" target="_blank" rel="noreferrer">Dashboard Power BI</a>
        </nav>
      </div>
    </header>

    <!-- KPIs -->
    <section class="grid kpis">
      <div class="card kpi">
        <div class="label">Avance diseño (semanal)</div>
        <div class="value" id="kpiProgress">72%</div>
        <div class="badge"><span class="dot"></span> En curso</div>
      </div>

      <div class="card kpi">
        <div class="label">Clashes abiertos</div>
        <div class="value" id="kpiClashes">28</div>
        <div class="badge"><span class="dot warn"></span> Requiere atención</div>
      </div>

      <div class="card kpi">
        <div class="label">RFIs pendientes</div>
        <div class="value" id="kpiRfis">12</div>
        <div class="badge"><span class="dot warn"></span> En seguimiento</div>
      </div>

      <div class="card kpi">
        <div class="label">Riesgos activos (alto)</div>
        <div class="value" id="kpiRisks">3</div>
        <div class="badge"><span class="dot bad"></span> Prioritario</div>
      </div>
    </section>

    <!-- Main -->
    <section class="grid main">
      <!-- Left -->
      <div class="card">
        <h2>Últimas incidencias (resumen)</h2>
        <p class="muted">Actualiza esta tabla con tu registro (puede venir de Google Sheets / Revizto / BCF).</p>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Disciplina</th>
              <th>Descripción</th>
              <th>Estado</th>
              <th>Responsable</th>
            </tr>
          </thead>
          <tbody id="issuesBody">
            <tr>
              <td>CL-102</td>
              <td>MEP vs Estructuras</td>
              <td>Interferencia ducto con viga en sala técnica</td>
              <td><span class="status"><span class="dot warn"></span> Abierta</span></td>
              <td>DIAR / PEDRASA</td>
            </tr>
            <tr>
              <td>CL-097</td>
              <td>Arquitectura vs MEP</td>
              <td>Falso positivo por tolerancia en bandeja</td>
              <td><span class="status"><span class="dot"></span> En revisión</span></td>
              <td>SAMADHI</td>
            </tr>
            <tr>
              <td>RFI-014</td>
              <td>General</td>
              <td>Confirmación de criterios de UPSS para ajuste de ambientes</td>
              <td><span class="status"><span class="dot warn"></span> Pendiente</span></td>
              <td>PMO / Cliente</td>
            </tr>
          </tbody>
        </table>

        <div style="height:12px"></div>
        <h2>Accesos rápidos</h2>
        <div class="links">
          <a class="btn secondary" href="#" id="lnkMidp" target="_blank" rel="noreferrer">MIDP/TIDP</a>
          <a class="btn secondary" href="#" id="lnkReports" target="_blank" rel="noreferrer">Reportes ejecutivos</a>
          <a class="btn secondary" href="#" id="lnkRiba" target="_blank" rel="noreferrer">Entregables RIBA</a>
          <a class="btn secondary" href="#" id="lnkAudits" target="_blank" rel="noreferrer">Auditorías BIM</a>
        </div>
      </div>

      <!-- Right -->
      <div class="cols">
        <div class="card">
          <h2>Próximas sesiones ICE</h2>
          <p class="muted">Registra decisiones y compromisos (PPM).</p>
          <table>
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Tema</th>
                <th>Resultado</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>2026-02-24</td>
                <td>Compatibilización MEP (zonas críticas)</td>
                <td><span class="status"><span class="dot"></span> Agendada</span></td>
              </tr>
              <tr>
                <td>2026-02-26</td>
                <td>Revisión PMA/PMF vs RIBA 3</td>
                <td><span class="status"><span class="dot warn"></span> Por confirmar</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card">
          <h2>Riesgos destacados</h2>
          <p class="muted">Semáforo para enfoque ejecutivo.</p>
          <table>
            <thead>
              <tr>
                <th>Riesgo</th>
                <th>Impacto</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Servidumbre / interferencia con infraestructura existente</td>
                <td>Alto</td>
                <td><span class="status"><span class="dot bad"></span> Alto</span></td>
              </tr>
              <tr>
                <td>Retrabajo por cambios tardíos de criterios clínicos</td>
                <td>Medio</td>
                <td><span class="status"><span class="dot warn"></span> Medio</span></td>
              </tr>
              <tr>
                <td>Falsos positivos en clashes (tolerancias)</td>
                <td>Bajo</td>
                <td><span class="status"><span class="dot"></span> Bajo</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card">
          <h2>Notas / anuncios</h2>
          <p class="muted">Coloca aquí comunicados clave (cortes semanales, hitos, entregables).</p>
          <ul class="muted" style="margin:0; padding-left:18px">
            <li>Corte semanal de métricas: <b>viernes 18:00</b></li>
            <li>Entrega RIBA 3: revisión interna + emisión a revisión externa</li>
            <li>Actualizar enlaces ACC por carpeta (01_Proyecto, 02_Disciplinas…)</li>
          </ul>
        </div>
      </div>
    </section>

    <div class="footer">
      © 2026 · Portal HDT · Consorcio SDD / DECHINI · Versión plantilla (ajusta enlaces y métricas reales)
    </div>
  </div>

  <script>
    // === CONFIGURA AQUÍ TUS ENLACES ===
    const LINKS = {
      acc: "https://construction.autodesk.com/",          // pon tu URL ACC
      revizto: "https://revizto.com/",                    // pon tu URL Revizto
      powerbi: "https://app.powerbi.com/",                // pon tu URL Power BI
      midp: "#",
      reports: "#",
      riba: "#",
      audits: "#"
    };

    // === CONFIGURA AQUÍ TUS KPIs (o reemplaza por datos reales) ===
    const KPIS = {
      progress: "72%",
      clashes: "28",
      rfis: "12",
      risks: "3",
      cutoff: new Date().toISOString().slice(0,10) // fecha hoy
    };

    document.getElementById("btnAcc").href = LINKS.acc;
    document.getElementById("btnRev").href = LINKS.revizto;
    document.getElementById("btnPbi").href = LINKS.powerbi;

    document.getElementById("lnkMidp").href = LINKS.midp;
    document.getElementById("lnkReports").href = LINKS.reports;
    document.getElementById("lnkRiba").href = LINKS.riba;
    document.getElementById("lnkAudits").href = LINKS.audits;

    document.getElementById("kpiProgress").textContent = KPIS.progress;
    document.getElementById("kpiClashes").textContent = KPIS.clashes;
    document.getElementById("kpiRfis").textContent = KPIS.rfis;
    document.getElementById("kpiRisks").textContent = KPIS.risks;
    document.getElementById("cutoff").textContent = KPIS.cutoff;
  </script>
</body>
</html>
